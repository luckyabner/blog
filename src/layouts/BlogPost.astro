---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	date?: Date;
	updatedDate?: Date;
	labels?: string[];
	headings?: { depth: number; slug: string; text: string }[];
}

const { title, date, updatedDate, labels = [], headings = [] } = Astro.props;
const toc = headings.filter((item) => item.depth >= 2 && item.depth <= 3);
---

<html lang="en">
	<head>
		<BaseHead title={title} description={title} />
		<style>
			main {
				max-width: 800px;
				padding: 2rem 1.25rem 5rem;
				margin: 0 auto;
				position: relative;
			}
			.article-header {
				margin-bottom: 3.5rem;
			}
			.back {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.95rem;
				color: var(--muted);
				text-decoration: none;
				margin-bottom: 2.5rem;
				font-weight: 500;
			}
			.back:hover {
				color: var(--text);
				text-decoration: underline;
				text-underline-offset: 0.2em;
			}
			.date {
				color: var(--muted);
				font-size: 0.95rem;
				margin-bottom: 0.75rem;
			}
			h1 {
				margin: 0;
				line-height: 1.15;
			}
			.lead {
				color: var(--muted);
				font-size: 1.15rem;
				max-width: 62ch;
				margin-top: 1.25rem;
				line-height: 1.6;
			}
			.labels {
				margin-top: 1.5rem;
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				list-style: none;
				padding: 0;
			}
			.labels li {
				font-size: 0.85rem;
				color: var(--muted);
				background: color-mix(in srgb, var(--surface-border) 40%, transparent);
				padding: 0.15rem 0.6rem;
				border-radius: 4px;
			}
			.article {
				min-width: 0;
			}
			.toc {
				display: none;
			}
			.toc h3 {
				font-size: 0.75rem;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				margin: 0 0 1rem;
				color: var(--muted);
			}
			.toc ul {
				padding: 0;
				margin: 0;
				list-style: none;
				display: grid;
				gap: 0.6rem;
			}
			.toc a {
				display: block;
				text-decoration: none;
				color: var(--muted);
				padding-left: 0.75rem;
				border-left: 1px solid var(--surface-border);
				font-size: 0.9rem;
				transition: all 0.15s ease;
			}
			.toc a:hover {
				color: var(--link);
				border-left-color: var(--link);
			}
			.prose :global(pre) {
				margin-left: -1rem;
				margin-right: -1rem;
			}
			@media (min-width: 1200px) {
				.toc {
					display: block;
					position: absolute;
					left: calc(100% + 3rem);
					top: 0;
					width: 200px;
					height: 100%;
				}
				.toc .inner {
					position: sticky;
					top: 2rem;
				}
			}
			@media (max-width: 640px) {
				.prose :global(pre) {
					margin-left: 0;
					margin-right: 0;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article class="article">
				<a class="back" href="/blog">← Back to list</a>
				<header class="article-header">
					{date && (
						<div class="date">
							<FormattedDate date={date} />
							{updatedDate && <> · Updated <FormattedDate date={updatedDate} /></>}
						</div>
					)}
					<h1>{title}</h1>
					{labels.length > 0 && (
						<ul class="labels">
							{labels.map((label) => <li>{label}</li>)}
						</ul>
					)}
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
			{toc.length > 0 && (
				<aside class="toc">
					<div class="inner">
						<h3>On this page</h3>
						<ul>
							{toc.map((item) => (
								<li><a href={`#${item.slug}`}>{item.text}</a></li>
							))}
						</ul>
					</div>
				</aside>
			)}
		</main>
		<Footer />
	</body>
</html>

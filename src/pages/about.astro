---
import { getCollection, render } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const pages = await getCollection(
	'pages',
	({ data, id }) => !data.labels.includes('hidden') && (id === 'about' || data.labels.includes('about')),
);
const aboutEntry = pages[0];
const rendered = aboutEntry ? await render(aboutEntry) : null;
const AboutContent = rendered?.Content;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About · ${SITE_TITLE}`} description="About this blog." />
	</head>
	<body>
		<Header />
		<main>
			<h1>{aboutEntry?.data.title ?? 'About'}</h1>
			{
				AboutContent ? (
					<article>
						<AboutContent />
					</article>
				) : (
					<p>No about content yet. Create an issue with label <code>about</code>.</p>
				)
			}
		</main>
		<Footer />
	</body>
</html>

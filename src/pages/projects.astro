---
import { getCollection, render } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const getDate = (entry) => entry.data.date ?? new Date(0);
const projects = (
	await getCollection('projects', ({ data }) => !data.labels.includes('hidden'))
).sort((a, b) => getDate(b).valueOf() - getDate(a).valueOf());
const renderedProjects = await Promise.all(
	projects.map(async (project) => ({ project, ...(await render(project)) })),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Portfolio · ${SITE_TITLE}`} description="Projects from labeled GitHub issues." />
		<style>
			.list {
				display: grid;
				gap: 4rem;
				margin-top: 3rem;
			}
			.item {
				border-top: 1px solid var(--surface-border);
				padding-top: 2rem;
			}
			.item h2 {
				margin: 0 0 0.5rem;
			}
			.meta {
				color: var(--muted);
				font-size: 0.95rem;
				margin-bottom: 1.5rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Portfolio</h1>
			{
				renderedProjects.length === 0 ? (
					<p>No project content yet. Create issues with label <code>projects</code>.</p>
				) : (
					<section class="list">
						{renderedProjects.map(({ project, Content }) => (
							<article class="item">
								<h2>{project.data.title}</h2>
								<p class="meta">
									<FormattedDate date={getDate(project)} />
								</p>
								<div class="prose">
									<Content />
								</div>
							</article>
						))}
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>

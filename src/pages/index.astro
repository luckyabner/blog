---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const getDate = (entry) => entry.data.date ?? entry.data.pubDate ?? new Date(0);
const getSlug = (entry) => entry.data.slug ?? entry.id;
const getSummary = (entry) =>
	entry.data.summary ?? entry.data.description ?? 'No summary yet.';

const blogPosts = (await getCollection('blog', ({ data }) => !data.hidden)).sort(
	(a, b) => getDate(b).valueOf() - getDate(a).valueOf(),
);
const projects = (await getCollection('projects', ({ data }) => !data.hidden)).sort(
	(a, b) => getDate(b).valueOf() - getDate(a).valueOf(),
);

const pinned = blogPosts.filter((post) => post.data.pinned).slice(0, 3);
const latest = blogPosts.slice(0, 8);
const projectPreview = projects.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.intro {
				margin-bottom: 2rem;
			}
			.section-title {
				font-size: 1rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--muted);
				margin-bottom: 0.75rem;
			}
			.entries {
				display: grid;
				gap: 1rem;
				padding: 0;
				list-style: none;
				margin: 0;
			}
			.entry {
				border: 1px solid var(--surface-border);
				border-radius: 0.65rem;
				padding: 0.9rem 1rem;
			}
			.entry h3 {
				margin: 0;
				font-size: 1.05rem;
			}
			.meta {
				color: var(--muted);
				font-size: 0.9rem;
				margin: 0.25rem 0 0.35rem;
			}
			.summary {
				margin: 0;
				color: var(--muted);
				font-size: 0.95rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<h1>{SITE_TITLE}</h1>
				<p>{SITE_DESCRIPTION}</p>
				<p>Write with GitHub Issues, publish with Astro.</p>
			</section>

			{pinned.length > 0 && (
				<section>
					<h2 class="section-title">Pinned</h2>
					<ul class="entries">
						{pinned.map((post) => (
							<li class="entry">
								<h3><a href={`/blog/${getSlug(post)}/`}>{post.data.title}</a></h3>
								<p class="meta">
									<FormattedDate date={getDate(post)} />
								</p>
								<p class="summary">{getSummary(post)}</p>
							</li>
						))}
					</ul>
				</section>
			)}

			<section>
				<h2 class="section-title">Latest Posts</h2>
				<ul class="entries">
					{latest.map((post) => (
						<li class="entry">
							<h3><a href={`/blog/${getSlug(post)}/`}>{post.data.title}</a></h3>
							<p class="meta">
								<FormattedDate date={getDate(post)} />
							</p>
							<p class="summary">{getSummary(post)}</p>
						</li>
					))}
				</ul>
			</section>

			{projectPreview.length > 0 && (
				<section>
					<h2 class="section-title">Projects</h2>
					<ul class="entries">
						{projectPreview.map((project) => (
							<li class="entry">
								<h3><a href="/projects">{project.data.title}</a></h3>
								<p class="summary">{getSummary(project)}</p>
							</li>
						))}
					</ul>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>

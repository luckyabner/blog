---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const getDate = (entry) => entry.data.date ?? new Date(0);
const getSlug = (entry) => entry.id;

const blogPosts = (
	await getCollection('blog', ({ data }) => !data.labels.includes('hidden'))
).sort((a, b) => getDate(b).valueOf() - getDate(a).valueOf());
const projects = (
	await getCollection('projects', ({ data }) => !data.labels.includes('hidden'))
).sort((a, b) => getDate(b).valueOf() - getDate(a).valueOf());

const latest = blogPosts.slice(0, 10);
const projectPreview = projects.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.home {
				max-width: 800px;
				margin: 0 auto;
			}
			.intro {
				margin-bottom: 4rem;
			}
			.intro h1 {
				margin-bottom: 0.5rem;
			}
			.intro p {
				max-width: 52ch;
				color: var(--muted);
				font-size: 1.1rem;
				line-height: 1.6;
			}
			.section {
				margin-bottom: 3.5rem;
			}
			.section-title {
				font-size: 0.8rem;
				font-weight: 700;
				letter-spacing: 0.05em;
				text-transform: uppercase;
				color: var(--muted);
				margin-bottom: 1.5rem;
				border-bottom: 1px solid var(--surface-border);
				padding-bottom: 0.5rem;
			}
			.entries {
				display: grid;
				gap: 0.75rem;
				padding: 0;
				list-style: none;
				margin: 0;
			}
			.entry {
				display: flex;
				align-items: baseline;
				gap: 1.5rem;
			}
			.entry .date {
				flex-shrink: 0;
				width: 100px;
				color: var(--muted);
				font-size: 0.9rem;
				font-variant-numeric: tabular-nums;
			}
			.entry h3 {
				margin: 0;
				font-size: 1.05rem;
				font-weight: 500;
			}
			.entry h3 a {
				color: var(--text);
				text-decoration: none;
			}
			.entry h3 a:hover {
				color: var(--link);
				text-decoration: underline;
				text-underline-offset: 0.2em;
			}
			@media (max-width: 640px) {
				.entry {
					flex-direction: column;
					gap: 0.2rem;
					margin-bottom: 0.5rem;
				}
				.entry .date {
					width: auto;
					font-size: 0.8rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="home">
				<section class="intro">
					<h1>{SITE_TITLE}</h1>
					<p>{SITE_DESCRIPTION}</p>
				</section>

				<section class="section">
					<h2 class="section-title">Writing</h2>
					<ul class="entries">
						{latest.map((post) => (
							<li class="entry">
								<span class="date"><FormattedDate date={getDate(post)} /></span>
								<h3><a href={`/blog/${getSlug(post)}/`}>{post.data.title}</a></h3>
							</li>
						))}
					</ul>
				</section>

				{projectPreview.length > 0 && (
					<section class="section">
						<h2 class="section-title">Works</h2>
						<ul class="entries">
							{projectPreview.map((project) => (
								<li class="entry">
									<span class="date"><FormattedDate date={getDate(project)} /></span>
									<h3><a href="/projects">{project.data.title}</a></h3>
								</li>
							))}
						</ul>
					</section>
				)}
			</div>
		</main>
		<Footer />
	</body>
</html>

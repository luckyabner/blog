---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const getDate = (entry) => entry.data.date ?? entry.data.pubDate ?? new Date(0);
const getSlug = (entry) => entry.data.slug ?? entry.id;
const getSummary = (entry) =>
	entry.data.summary ?? entry.data.description ?? 'No summary yet.';

const posts = (await getCollection('blog', ({ data }) => !data.hidden)).sort(
	(a, b) => getDate(b).valueOf() - getDate(a).valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.entries {
				display: grid;
				gap: 1rem;
				margin: 0;
				padding: 0;
				list-style: none;
			}
			.entry {
				border: 1px solid var(--surface-border);
				border-radius: 0.65rem;
				padding: 0.9rem 1rem;
			}
			.entry h2 {
				margin: 0;
				font-size: 1.1rem;
			}
			.date {
				margin: 0.3rem 0 0.4rem;
				color: var(--muted);
				font-size: 0.9rem;
			}
			.summary {
				margin: 0;
				color: var(--muted);
				font-size: 0.95rem;
			}
			.empty {
				color: var(--muted);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<h1>Blog</h1>
				{posts.length === 0 ? (
					<p class="empty">No posts yet. Create a new GitHub Issue to publish one.</p>
				) : (
					<ul class="entries">
						{posts.map((post) => (
							<li class="entry">
								<h2><a href={`/blog/${getSlug(post)}/`}>{post.data.title}</a></h2>
								<p class="date">
									<FormattedDate date={getDate(post)} />
								</p>
								<p class="summary">{getSummary(post)}</p>
							</li>
						))}
					</ul>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>
